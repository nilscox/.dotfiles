output eDP-1 mode 1920x1200 position 0,0

profile laptop {
  exec bash -c 'swaymsg mouse_warping output'
}

profile work {
  output HDMI-A-1 mode 3840x2160 scale 1.25 position 0,0
  output DP-2 mode 3840x2160 scale 1.25 position 3072,0
  output eDP-1 position 6144,528
  exec bash -c 'swaymsg mouse_warping none'
}

profile tv {
  output HDMI-A-1 mode 3840x2160 position 0,0 scale 1.5
  output eDP-1 position 2560,240
  exec bash -c 'swaymsg mouse_warping output'
}
